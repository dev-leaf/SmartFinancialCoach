# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/smart_expense_db"

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:4200

# Auth (required in production)
JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-long-random-string

# Market data (required for stock prices)
ALPHA_VANTAGE_API_KEY=
USD_TO_INR_RATE=83.5

# Optional LLM enrichment (Insights)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
